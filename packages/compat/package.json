{
	"name": "@ogerjs/compat",
	"version": "0.1.0",
	"type": "module",
	"main": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./register": {
			"types": "./dist/register.d.ts",
			"default": "./dist/register.js"
		},
		"./bun": {
			"types": "./dist/bun-shim.d.ts",
			"default": "./dist/bun-shim.js"
		},
		"./sqlite": {
			"types": "./dist/sqlite.d.ts",
			"default": "./dist/sqlite.js"
		},
		"./jsc": {
			"types": "./dist/jsc.d.ts",
			"default": "./dist/jsc.js"
		},
		"./ffi": {
			"types": "./dist/ffi.d.ts",
			"default": "./dist/ffi.js"
		},
		"./test": {
			"types": "./dist/test-shim.d.ts",
			"default": "./dist/test-shim.js"
		}

	},
	"dependencies": {
		"@ogerjs/core": "workspace:*"
	},
	"scripts": {
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"build": "bun run ../../scripts/build.ts",
		"test": "bun test"
	},
	"ogerjs": {
		"plugin": true,
		"export": "compat"
	},
	"types": "./dist/index.d.ts",
	"devDependencies": {
		"@ogerjs/testing": "workspace:*"
	},
	"author": "Ogulcan Studio",
	"license": "MIT",
	"homepage": "https://ogulcan.studio",
	"bugs": {
		"url": "https://github.com/OgulcanStudio/OgerJS/issues",
		"email": "npm@ogulcan.studio"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OgulcanStudio/OgerJS.git"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"files": [
		"dist"
	],
	"description": "Cross-runtime helpers (Node + Bun) for OgerJS apps.",
	"keywords": [
		"ogerjs",
		"bun",
		"http",
		"typescript",
		"framework",
		"plugin",
		"compat"
	]
}
